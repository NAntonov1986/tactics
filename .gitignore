# Локальные бекапы проекта (220 МБ, делаются вручную перед каждой сессией —
# не должны попадать в git, история и так сохраняется коммитами).
backup/

# Системные мусорные файлы Windows/macOS, которые создают проводники.
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Папки IDE/редакторов — личные настройки разработчика, не общие для проекта.
.vscode/
.idea/
*.swp
*~

# Локальные настройки Claude Code (если появятся). settings.json при желании
# можно потом раскомментировать и закоммитить, settings.local.json — личное.
.claude/settings.local.json

# Логи и временные артефакты.
*.log
*.tmp
*.bak

# Node — на случай если в будущем подключим сборщик.
node_modules/

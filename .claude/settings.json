{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-edit-backup.py",
            "timeout": 10,
            "statusMessage": "Бэкап перед правкой..."
          }
        ]
      }
    ]
  }
}
